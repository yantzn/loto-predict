APP_ENV=local
APP_TIMEZONE=Asia/Tokyo
LOG_LEVEL=INFO

GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast1

BIGQUERY_DATASET=loto_predict
BQ_TABLE_EXECUTION_LOGS=execution_logs
BQ_TABLE_LOTO6_HISTORY=loto6_history
BQ_TABLE_LOTO7_HISTORY=loto7_history
BQ_TABLE_PREDICTION_RUNS=prediction_runs

GCS_BUCKET_RAW=your-raw-bucket-name

PUBSUB_IMPORT_TOPIC=import-loto-results
PUBSUB_NOTIFY_TOPIC=notify-loto-prediction

HISTORY_LIMIT_LOTO6=100
HISTORY_LIMIT_LOTO7=100

LOTO6_SOURCE_URL=https://takarakuji.rakuten.co.jp/backnumber/loto6/
LOTO7_SOURCE_URL=https://takarakuji.rakuten.co.jp/backnumber/loto7/
REQUEST_TIMEOUT_SECONDS=60
HTTP_USER_AGENT=loto-predict-local/1.0

LINE_CHANNEL_ACCESS_TOKEN=あなたのLINEチャネルアクセストークン
LINE_TO_USER_ID=あなたの送信先ユーザーID
