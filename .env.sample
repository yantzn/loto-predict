APP_ENV=local  # アプリケーションの実行環境（例: local, production）
APP_TIMEZONE=Asia/Tokyo  # アプリケーションで使用するタイムゾーン

GCP_PROJECT_ID=loto-predict-491915  # Google Cloud PlatformのプロジェクトID
GCP_REGION=asia-northeast1  # GCPリソースのリージョン
BIGQUERY_DATASET=loto_predict  # BigQueryで使用するデータセット名

LOG_LEVEL=INFO  # ログ出力レベル（例: INFO, DEBUG, ERROR）
LOG_JSON=true  # ログをJSON形式で出力するかどうか
LOG_EXECUTION_ID=true  # ログに実行IDを含めるかどうか
SERVICE_NAME=loto-predict-line  # サービス名

STATS_TARGET_DRAWS=100  # 統計計算対象の過去抽選回数
PREDICTION_COUNT=5  # 予測する組み合わせ数

LOTO6_NUMBER_MIN=1  # ロト6の最小数字
LOTO6_NUMBER_MAX=43  # ロト6の最大数字
LOTO6_PICK_COUNT=6  # ロト6の抽選数字数

LOTO7_NUMBER_MIN=1  # ロト7の最小数字
LOTO7_NUMBER_MAX=37  # ロト7の最大数字
LOTO7_PICK_COUNT=7  # ロト7の抽選数字数

LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token  # LINE Messaging APIのチャネルアクセストークン
LINE_USER_ID=your_line_user_id  # 通知先のLINEユーザーID
