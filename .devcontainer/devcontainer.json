{
  "name": "loto-predict-terraform",
  "dockerComposeFile": "docker-compose.yml",
  "service": "terraform",
  "workspaceFolder": "/workspace",
  "remoteUser": "vscode",
  "postCreateCommand": "terraform -version && gcloud --version && git --version",
  "customizations": {
    "vscode": {
      "extensions": [
        "hashicorp.terraform",
        "googlecloudtools.cloudcode",
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens"
      ],
      "settings": {
        "terraform.languageServer.enable": true
      }
    }
  }
}
